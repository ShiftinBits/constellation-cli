{
	"name": "@constellationdev/cli",
	"description": "Code Intelligence Platform for AI Coding Agents",
	"version": "0.2.2",
	"author": "ShiftinBits Inc",
	"main": "dist/main.js",
	"type": "module",
	"types": "dist/index.d.ts",
	"bin": {
		"constellation": "dist/main.js"
	},
	"scripts": {
		"build": "rimraf dist && tsup",
		"start": "tsx src/main.ts",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"lint:errors": "eslint --quiet",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "jest --coverage",
		"test:ci": "jest --ci --coverage --maxWorkers=2",
		"type-check": "tsc --noEmit -p tsconfig.build.json",
		"prepare": "node -e \"try{require('husky').default()}catch(e){}\"",
		"postinstall": "node -e \"if(process.env.CI) { console.log('Using github sourced @constellationdev/types') } else { try { require('child_process').execSync('npm link @constellationdev/types', {stdio: 'inherit'}); console.log('Using locally linked @constellationdev/types') } catch(e) { console.log('Note: @constellationdev/types not linked globally, using GitHub version') } }\""
	},
	"dependencies": {
		"@constellationdev/types": "github:ShiftinBits/constellation-types#main",
		"@iarna/toml": "^3.0.0",
		"@scure/base": "^2.0.0",
		"ansi-colors": "^4.1.3",
		"commander": "^14.0.1",
		"enquirer": "^2.4.1",
		"ignore": "^7.0.5",
		"simple-git": "^3.28.0",
		"tree-sitter": "^0.21.1",
		"tree-sitter-javascript": "^0.21.4",
		"tree-sitter-python": "^0.21.0",
		"tree-sitter-typescript": "^0.21.2",
		"tsconfck": "^3.1.6",
		"undici": "^7.22.0",
		"yaml": "^2.8.3",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/compat": "^1",
		"@jest/globals": "^30.2.0",
		"@types/iarna__toml": "^2.0.4",
		"@types/jest": "^30.0.0",
		"@types/node": "^24",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"husky": "^9.1.7",
		"jest": "^30.2.0",
		"lint-staged": "^16.2.7",
		"prettier": "^3.7.4",
		"rimraf": "^6.0.1",
		"ts-jest": "^29.4.5",
		"ts-node": "^10.9.2",
		"tsup": "^8.5.1",
		"tsx": "^4.20.6",
		"typescript": "~5.9.3"
	},
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=11.0.0"
	},
	"files": [
		"dist"
	],
	"homepage": "https://constellationdev.io",
	"bugs": "https://github.com/ShiftinBits/constellation-cli/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ShiftinBits/constellation-cli.git"
	},
	"keywords": [
		"constellation",
		"mcp",
		"model",
		"context",
		"protocol",
		"ai",
		"server",
		"tree-sitter",
		"shiftinbits"
	],
	"license": "AGPL-3.0-only",
	"lint-staged": {
		"*.{ts,tsx}": [
			"eslint --fix --quiet",
			"prettier --write"
		],
		"*.{js,jsx,mjs}": [
			"eslint --fix --quiet",
			"prettier --write"
		],
		"*.{json,md,css}": [
			"prettier --write"
		]
	}
}
