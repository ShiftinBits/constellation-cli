{
	"compilerOptions": {
		"declaration": true,
		"module": "ESNext",
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"target": "ESNext",
		"lib": ["ESNext"],
		"types": ["node"],
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["./src/**/*"],
	"ts-node": {
		"esm": true,
		"experimentalSpecifierResolution": "node"
	}
}
